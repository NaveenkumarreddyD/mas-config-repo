
# Copy to env4.env and fill in. Only these ~6 lines really differ per cluster.
ACCOUNT_ID=mas
REGION_ID=lac1
CLUSTER_ID=env4
INSTANCE_ID=gitopsapp
# Dedicated Mongo namespace — MUST equal platform-gitops gitops/envs/<cluster>/values.yaml
# mongo.namespace. Convention is mongo-<INSTANCE_ID>; set it explicitly, do not rely on defaults.
MONGO_NS=mongo-gitopsapp
WORKSPACE_ID=gitopswks

# Same-cluster Argo CD: https://kubernetes.default.svc
# Remote registered cluster: https://api.<cluster-domain>:6443
CLUSTER_URL=https://kubernetes.default.svc
MAS_DOMAIN=CHANGE_ME_MAS_DOMAIN
OPERATIONAL_MODE=nonproduction

MAS_CHANNEL=8.11.x
MAS_APP_CHANNEL=8.7.x
MAS_TARGET_VERSION=8.11.26
MANAGE_TARGET_VERSION=8.7.24
MANAGE_COMPONENT_VERSION=8.7.24
MANAGE_AUTO_GENERATE_ENCRYPTION_KEYS=true
MAS_EDITION=essentials-maintenance
SLS_CHANNEL=CHANGE_ME_SLS_CHANNEL

MAS_CATALOG_VERSION=v9-240625-amd64
MAS_CATALOG_IMAGE=icr.io/cpopen/ibm-maximo-operator-catalog
STORAGE_CLASS=isilon
RWX_STORAGE_CLASS=isilon
DRO_NAMESPACE=ibm-software-central
DRO_CONTACT_EMAIL=CHANGE_ME
DRO_CONTACT_FIRSTNAME=CHANGE_ME
DRO_CONTACT_LASTNAME=CHANGE_ME
MAS_FEATURE_USAGE=true
MAS_DEPLOYMENT_PROGRESSION=true
MAS_USABILITY_METRICS=true
MAS_CONTRACT_PERFORMANCE=true
SERVER_TIMEZONE=America/Chicago
DB_SCHEMA=maximo
DB_TABLESPACE=MAX_DATA
DB_INDEXSPACE=MAX_INDEX
GITOPS_OWNS_CERT_MANAGER=true
SHARED_CLUSTER_SKIP=

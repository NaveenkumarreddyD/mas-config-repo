# Per-cluster values for drroc4 (the ONLY things that change between envs)
ACCOUNT_ID=mas
REGION_ID=lac1
CLUSTER_ID=drroc4
INSTANCE_ID=drgitopsapp
# Dedicated Mongo namespace — MUST match platform-gitops mongodbCE.namespace.
# load-secrets.sh uses this to build mongo#host; Core + SLS both read mongo#host.
MONGO_NS=mongo-drgitops
WORKSPACE_ID=drgitopswks

# Same-cluster Argo CD destination. Use the external API URL only for a registered remote cluster.
CLUSTER_URL=https://kubernetes.default.svc
MAS_DOMAIN=drgitopsapp.apps.drroc4.lac1.biz
OPERATIONAL_MODE=nonproduction

# ============================================================================
# TARGET VERSION PINS
# Keep these explicit so a fresh GitOps install resolves the expected MAS,
# Manage, SLS, and catalog content instead of drifting with defaults.
# ============================================================================

# --- Target versions / channels ---
# IBM GitOps exposes channels for MAS operators; exact operator versions are resolved
# by the pinned MAS catalog content below. The v9-250925-amd64 (Sep 25 2025) catalog
# resolves the 8.11.x / 8.7.x channels to MAS 8.11.26, Manage 8.7.24, SLS 3.12.2.
# NOTE: Manage 8.7.24 is REQUIRED here because the existing Maximo database was
# initialized at the 8.7.24 schema (DB build V81100-50). Running an older Manage
# (e.g. 8.7.9 from the v9-240625 catalog) fails: "Installed database is newer than
# current release database." So the catalog tag below MUST stay on 8.7.24 content.
MAS_TARGET_VERSION=8.11.26
MANAGE_TARGET_VERSION=8.7.24
MANAGE_COMPONENT_VERSION=8.7.24
MANAGE_AUTO_GENERATE_ENCRYPTION_KEYS=true

# --- Channels (must equal the target Subscription channels) ---
MAS_CHANNEL=8.11.x
MAS_APP_CHANNEL=8.7.x
# SLS channel — used by the dedicated SLS (base/instance/ibm-sls.yaml -> 100-ibm-sls Subscription)
SLS_CHANNEL=3.x
MAS_EDITION=essentials-maintenance

# --- Operator catalog: THE master version pin ---
# This dated tag is the master pin for ALL MAS app versions. v9-250925-amd64 ships
# core 8.11.26 / Manage 8.7.24 / SLS 3.12.2 (verified against the IBM catalog manifest),
# which is what this cluster's database requires. Dated vX-YYMMDD tags are point-in-time
# snapshots (unlike the floating `latest`), so this is reproducible across reinstalls.
# For absolute immutability you may pin by digest instead of tag:
#   v9-250925-amd64 -> sha256:db5ac0b24bc6c0cb2af8eebcf529fee8ce944196d49aaf7448a00b6e9ffa8d96
# (Do NOT revert to v9-240625-amd64: that catalog is Manage 8.7.9 and breaks the 8.7.24 DB.)
MAS_CATALOG_IMAGE=icr.io/cpopen/ibm-maximo-operator-catalog
MAS_CATALOG_VERSION=v9-250925-amd64


STORAGE_CLASS=isilon
RWX_STORAGE_CLASS=isilon
DRO_NAMESPACE=ibm-software-central
DRO_CONTACT_EMAIL=Najeeb.Mehboob@spireenergy.com
DRO_CONTACT_FIRSTNAME=Najeeb
DRO_CONTACT_LASTNAME=Mehboob
# Fully declarative — NO staging toggles. Every config (Mongo/SLS/JDBC/BAS) and app (DRO, Manage)
# renders from the start. Runtime-dependent configs sit Degraded until their registration is
# harvested into Vault, then converge (harvest + bounce_until_ready). DRO is always deployed (the
# Suite requires BASIntegrationReady); Manage auto-installs once the Suite is Ready.
# The values below are real CONFIG (Suite usage-reporting settings), not staging gates:
MAS_FEATURE_USAGE=false
MAS_DEPLOYMENT_PROGRESSION=false
MAS_USABILITY_METRICS=false
MAS_CONTRACT_PERFORMANCE=false
SERVER_TIMEZONE=America/Chicago
DB_SCHEMA=maximo
DB_TABLESPACE=MAX_DATA
DB_INDEXSPACE=MAX_INDEX

# Cluster ownership: only whether GITOPS installs cert-manager (set false if the cluster already
# has cert-manager). DRO is always deployed now — there is no GITOPS_OWNS_DRO toggle.
GITOPS_OWNS_CERT_MANAGER=false
# Optional emergency override: comma-separated rendered cluster files to suppress.
# Example: redhat-cert-manager.yaml,ibm-dro.yaml
SHARED_CLUSTER_SKIP=

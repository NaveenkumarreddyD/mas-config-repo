# Per-cluster values for drroc4 (the ONLY things that change between envs)
ACCOUNT_ID=mas
REGION_ID=lac1
CLUSTER_ID=drroc4
INSTANCE_ID=drgitopsapp
# Dedicated Mongo namespace — MUST match platform-gitops mongodbCE.namespace.
# load-secrets.sh uses this to build mongo#host; Core + SLS both read mongo#host.
MONGO_NS=mongo-drgitops
WORKSPACE_ID=drgitopswks

API_HOST=CHANGE_ME_DRROC4_API
MAS_DOMAIN=CHANGE_ME_DRGITOPSAPP_MAS_DOMAIN
OPERATIONAL_MODE=nonproduction

# ============================================================================
# VERSION ALIGNMENT  —  must match the running Ansible install (drmasapp)
# Run:  scripts/gather-ansible-versions.sh
# It prints exactly what to paste below. Do NOT guess these.
# ============================================================================

# --- Channels (must equal the Ansible Subscription channels) ---
# MAS Core channel (Ansible ref: ibm-mas sub in mas-drmasapp-core)
MAS_CHANNEL=8.11.x
# Manage channel (Ansible ref: ibm-mas-manage sub in mas-drmasapp-manage)
MAS_APP_CHANNEL=8.7.x
# SLS channel — used by the dedicated SLS (base/instance/ibm-sls.yaml -> 100-ibm-sls Subscription)
SLS_CHANNEL=3.x
MAS_EDITION=essentials-maintenance

# --- Operator catalog: THE master version pin ---
# Ansible and GitOps must resolve operators from the SAME catalog content.
# The vX-YYMMDD tag is re-pushed in place (it FLOATS), which is why a fresh
# GitOps install can land on a different CSV than Ansible. For reproducible
# parity, pin by DIGEST. The gather script prints the digest the cluster serves.
#
# Catalog by TAG — matches the running cluster catalog; IBM chart builds image:tag and uses the
# value in the CatalogSource displayName too. The tag floats (registryPoll 45m), but v9-240625-amd64
# currently resolves to the 8.11.26 / 8.7.24 / 3.12.2 content. For a hard pin see docs/version-alignment.md.
MAS_CATALOG_IMAGE=icr.io/cpopen/ibm-maximo-operator-catalog
MAS_CATALOG_VERSION=v9-240625-amd64


STORAGE_CLASS=isilon
RWX_STORAGE_CLASS=isilon
DRO_NAMESPACE=ibm-software-central
DRO_CONTACT_EMAIL=Najeeb.Mehboob@spireenergy.com
DRO_CONTACT_FIRSTNAME=Najeeb
DRO_CONTACT_LASTNAME=Mehboob
SERVER_TIMEZONE=America/Chicago
DB_SCHEMA=maximo
DB_TABLESPACE=MAX_DATA
DB_INDEXSPACE=MAX_INDEX

# Shared cluster (4 MAS instances): don't emit cluster-scoped apps that collide
# with Ansible-installed cert-manager/DRO. render.py auto-skips these files.
SHARED_CLUSTER=true
SHARED_CLUSTER_SKIP=redhat-cert-manager.yaml,ibm-dro.yaml

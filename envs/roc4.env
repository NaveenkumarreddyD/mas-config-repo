
# Per-cluster values for roc4 (production example)
ACCOUNT_ID=mas
REGION_ID=lac1
CLUSTER_ID=roc4
# INSTANCE_ID + MONGO_NS MUST match platform-gitops gitops/envs/roc4/values.yaml
# (instanceId: rmasapp, mongo.namespace: mongo-rmasapp). Keep both repos in sync.
INSTANCE_ID=rmasapp
WORKSPACE_ID=rmasappwks
# Dedicated Mongo namespace — MUST equal platform-gitops mongo.namespace for this cluster.
MONGO_NS=mongo-rmasapp

# Same-cluster Argo CD destination. For a remote registered cluster, use https://api.<cluster>:6443.
CLUSTER_URL=https://kubernetes.default.svc
MAS_DOMAIN=CHANGE_ME_ROC4_MAS_DOMAIN
OPERATIONAL_MODE=production

MAS_CHANNEL=8.11.x
MAS_APP_CHANNEL=8.7.x
MAS_TARGET_VERSION=8.11.26
MANAGE_TARGET_VERSION=8.7.24
MANAGE_COMPONENT_VERSION=8.7.24
MANAGE_AUTO_GENERATE_ENCRYPTION_KEYS=true
MAS_EDITION=essentials-maintenance
SLS_CHANNEL=CHANGE_ME_SLS_CHANNEL


MAS_CATALOG_VERSION=v9-240625-amd64
MAS_CATALOG_IMAGE=icr.io/cpopen/ibm-maximo-operator-catalog

STORAGE_CLASS=isilon
RWX_STORAGE_CLASS=isilon
DRO_NAMESPACE=ibm-software-central
DRO_CONTACT_EMAIL=CHANGE_ME
DRO_CONTACT_FIRSTNAME=CHANGE_ME
DRO_CONTACT_LASTNAME=CHANGE_ME
ENABLE_BAS_CONFIG=false
MAS_FEATURE_USAGE=false
MAS_DEPLOYMENT_PROGRESSION=false
MAS_USABILITY_METRICS=false
MAS_CONTRACT_PERFORMANCE=false
SERVER_TIMEZONE=America/Chicago
DB_SCHEMA=maximo
DB_TABLESPACE=MAX_DATA
DB_INDEXSPACE=MAX_INDEX

# Per-cluster values for roc4 (production example)
ACCOUNT_ID=mas
REGION_ID=lac1
CLUSTER_ID=roc4
INSTANCE_ID=gitopsapp
WORKSPACE_ID=gitopswks

API_HOST=CHANGE_ME_ROC4_API
